<!DOCTYPE html>
<html>
  <head>
    <title>Tacostagram Final</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- My own CSS -->
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg mb-3" data-bs-theme="dark" style="background: linear-gradient(to right, #f97316, #ec4899, #8b5cf6);">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Tacostagram</a>
        <div class="navbar-nav">
          <% @current_user = User.find_by({ "id" => session["user_id"] }) %>
          <% if @current_user != nil %>
            <span class="navbar-text me-3">Welcome, <%= @current_user["username"] %>!</span>
            <a class="nav-link" href="/logout">Logout</a>
          <% else %>
            <a class="nav-link" href="/login">Login</a>
            <a class="nav-link" href="/signup">Signup</a>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container">
      <% if flash["notice"] %>
        <div class="alert alert-info"><%= flash["notice"] %></div>
      <% end %>
      <%= yield %>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>